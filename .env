# MongoDB Bağlantı Ayarları
# Yerel geliştirme için: mongodb://localhost:27017/sahabeler
# MongoDB Atlas için: mongodb+srv://username:password@cluster.mongodb.net/sahabeler
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=admin123
MONGODB_PORT=27017
MONGODB_DB_NAME=sahabeler
MONGODB_URI=mongodb://admin:admin123@100.68.72.10:27017/sahabeler?authSource=admin

# JWT Konfigürasyonu
# Üretim ortamında güvenli bir secret key oluşturun
# Örnek: openssl rand -base64 32
JWT_SECRET=your-secret-key-here-change-in-productionxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Node Ortamı
NODE_ENV=development

# API Konfigürasyonu
# Geliştirme için /api, üretim için tam URL kullanın
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Sunucu Portu
PORT=3000
